   "source": [
    "from datetime import date, timedelta\n",
    "import requests\n",
    "import pandas as pd\n",
    "import time\n",
    "\n",
    "API_KEY = \""\n",
    "headers = {\"X-eBirdApiToken\": API_KEY}\n",
    "results = []\n",
    "\n",
    "#Common migratory bird species in Schleswig-Holstein\n",
    "MIGRATORY_BIRDS = {\n",
    "    \"brant\": \"Ringelgans\",\n",
    "    \"dunlin\": \"Alpenstrandläufer\",\n",
    "    \"bargoo\": \"Weißwangengans\",\n",
    "    \"euroys1\": \"Austernfischer\",\n",
    "    \"redkno\": \"Knutt\"\n",
    "}\n",
    "\n",
    "def get_migratory_data(Region, Date):\n",
    "\n",
    "    URL = f\"https://api.ebird.org/v2/data/obs/{Region}/historic/{Date}\"\n",
    "\n",
    "    parameters = {\n",
    "        \"includeProvisional\": \"true\",\n",
    "        \"hotspot\": \"false\"\n",
    "    }\n",
    "\n",
    "    print(f\"Starting request for {Region} on the {Date}\")\n",
    "    response = requests.get(URL, headers=headers, params=parameters)\n",
    "\n",
    "    if response.status_code == 200:\n",
    "        data = response.json()\n",
    "        # § LLM help to split the months into seasons\n",
    "        month = int(Date.split(\"/\")[1])\n",
    "        season = \"Spring\" if month in [3, 4, 5] else \"Autumn\"\n",
    "\n",
    "        for obs in data:\n",
    "            #get the eBird species code for every migratory bird\n",
    "            bird_code = obs.get(\"speciesCode\")\n",
    "            #columns of the csv file\n",
    "            if bird_code in MIGRATORY_BIRDS:\n",
    "                results.append({\n",
    "                    \"Date\": Date,\n",
    "                    \"Year\": Date.split(\"/\")[0],\n",
    "                    \"Month\": month,\n",
    "                    \"Season\": season,\n",
    "                    \"Region\": Region,\n",
    "                    \"Species\": MIGRATORY_BIRDS[bird_code],\n",
    "                    \"Count\": obs.get(\"howMany\", 0)    \n",
    "                })\n",
    "    else: \n",
    "        print(f\"Error message: {response.status_code}\")\n",
    "        print(response.text)\n",
    "#wanted time interval\n",
    "months = [3, 4, 5, 9, 10, 11]   \n",
    "start_date = date(2021, 1, 1)\n",
    "end_date = date(2025,12,31)\n",
    "\n",
    "total_days = (end_date - start_date).days\n",
    "\n",
    "# § LLM help using timedelta\n",
    "for i in range(total_days + 1):\n",
    "    current_date = start_date + timedelta(days=i)\n",
    "    #Check if month is relevant\n",
    "    if current_date.month in months:                    \n",
    "        formatted_date = current_date.strftime(\"%Y/%m/%d\")\n",
    "        get_migratory_data(\"DE-SH\", formatted_date)\n",
    "        time.sleep(0.1)\n",
    "    else:\n",
    "        continue\n",
    "\n",
    "df = pd.DataFrame(results)\n",
    "df.to_csv(\"migratory_observations_SH_2021-2025.csv\", index=False)\n",
    "print(\"Data saved as: migratory_observations_SH_2021-2025.csvv\")\n",
    "print(\"------Done------\")"
   ]
  }
 ],
